{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Rust Project",
            "detail": "Run Rust application",
            "type": "shell",
            "command": "cargo",
            "args": [
                "run"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": [
                "$rustc"
            ],
            "runOptions": {
                "reevaluateOnRerun": true
            },
            "options": {
                "statusbar": {
                    "label": "$(debug-start) Run"
                }
            }
        }
        ,
        {
            "label": "Build",
            "detail": "Build Rust application",
            "type": "shell",
            "command": "cargo build --release",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$rustc"
            ],
            "runOptions": {
                "reevaluateOnRerun": true
            },
            "options": {
                "statusbar": {
                    "label": "$(build) Build"
                }
            }
        },
        {
            "label": "Test",
            "detail": "Test Rust application",
            "type": "shell",
            "command": "cargo test --workspace",
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "problemMatcher": [
                "$rustc"
            ],
            "runOptions": {
                "reevaluateOnRerun": true
            },
            "options": {
                "statusbar": {
                    "label": "$(beaker) Test"
                }
            }
        }
        ,
        {
            "label": "Clippy",
            "detail": "Run Clippy Test",
            "type": "shell",
            "command": "cargo clippy",
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "problemMatcher": [
                "$rustc"
            ],
            "runOptions": {
                "reevaluateOnRerun": true
            },
            "options": {
                "statusbar": {
                    "label": "$(sparkle) Clippy"
                }
            }
        }
    ]
}