<main>
    <let>
        <name>i</name>
        <value>
            <i32>0</i32>
        </value>
    </let>

    <while>
        <test>
            <lt>
                <i />
                <i32>5</i32>
            </lt>
        </test>

        <body>
            <call println>
                <i />
            </call>

            <i>
                <sum>
                    <i />
                    <i32>1</i32>
                </sum>
            </i>
        </body>
    </while>
</main>