<main>
    <let>
        <name>target_a</name>
        <value>
            <i32>100</i32>
        </value>
    </let>
    <let>
        <name>target_b</name>
        <value>
            <i32>200</i32>
        </value>
    </let>
    <let>
        <name>flag</name>
        <value>
            <bool>0</bool>
        </value>
    </let>

    <let>
        <name>dynamic_ptr</name>
        <value>
            <target_a ref />
        </value>
    </let>

    <if>
        <test>
            <eq>
                <flag />
                <bool>1</bool>
            </eq>
        </test>
        <then>
            <dynamic_ptr>
                <target_a ref />
            </dynamic_ptr>
        </then>
        <else>
            <dynamic_ptr>
                <target_b ref />
            </dynamic_ptr>
        </else>
    </if>

    <call println>
        <dynamic_ptr deref />
    </call>

    <dynamic_ptr deref>
        <i32>999</i32>
    </dynamic_ptr>

    <call println>
        <target_b />
    </call>
</main>