<mod>
    <let>
        <name>name</name>
        <value>
            <str>math</str>
        </value>
    </let>

    <fn>
        <name>abc</name>

        <body>
            <println$>
                <concat$>
                    <str>Hello </str>
                    <name />
                </concat$>
            </println$>
        </body>
    </fn>

    <export>
        <abc />
    </export>
</mod>